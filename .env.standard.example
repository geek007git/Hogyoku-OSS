# =============================================================================
# TIER 2 — STANDARD (~$0-15/month, mostly free managed tiers)
# =============================================================================
# Small, low-traffic production using free or cheap managed services so you
# stop babysitting a local machine. Each value below comes from a provider
# dashboard. Copy this file to .env on your host or paste values into your
# platform's secret manager.
#
#   cp .env.standard.example .env
#
# Suggested free/cheap providers (all interchangeable):
#   - Postgres + pgvector : Neon (free), Supabase (free)
#   - Redis               : Upstash (free), Redis Cloud (free 30MB)
#   - Object storage      : Cloudflare R2 (free egress), Backblaze B2
#   - Web + worker        : Render / Railway / Fly.io (hobby tiers)
#   - Model               : Gemini pay-as-you-go (flash-lite is very cheap)
# =============================================================================

NODE_ENV=production
PORT=4173

# Your deployed HTTPS URL
APP_ORIGIN=https://hogyoku.example.com

# Neon/Supabase connection string (must have the `vector` extension)
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Upstash / Redis Cloud TLS URL
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# Cloudflare R2 example (path-style). For AWS S3 set FORCE_PATH_STYLE=false.
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=hogyoku
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_FORCE_PATH_STYLE=true

# 64+ random characters. Store in your platform secret manager, not in Git.
SESSION_SECRET=replace-with-a-64-character-random-secret

# Pay-as-you-go key. flash-lite keeps spend near zero for low volume.
GEMINI_API_KEY=your-google-ai-studio-key
CHAT_MODEL=gemini-2.5-flash-lite
VISION_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536

MAX_UPLOAD_MB=40
LOG_LEVEL=info
