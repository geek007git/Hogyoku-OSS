# =============================================================================
# TIER 1 — FREE ($0/month)
# =============================================================================
# Everything runs locally with Docker Compose. No cloud account, no card.
# Copy this file to .env and run: docker compose up --build
#
#   cp .env.free.example .env
#
# Optional: add a free Google AI Studio key for generated + verified answers.
# Without a key, Hogyoku uses deterministic local embeddings, extractive
# answers, and offline follow-up query rewriting. It still fully works.
# =============================================================================

NODE_ENV=development
PORT=4173
APP_ORIGIN=http://localhost:4173

# Local Docker services (defined in docker-compose.yml)
DATABASE_URL=postgres://hogyoku:hogyoku@localhost:5432/hogyoku
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hogyoku
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_FORCE_PATH_STYLE=true

# Generate locally:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace-with-at-least-32-random-characters

# Optional. Free tier key from https://aistudio.google.com/app/apikey
# Leave blank for fully offline operation.
GEMINI_API_KEY=

# Free-tier-friendly models (the "lite" model is the cheapest/free option)
CHAT_MODEL=gemini-2.5-flash-lite
VISION_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536

MAX_UPLOAD_MB=40
LOG_LEVEL=info
