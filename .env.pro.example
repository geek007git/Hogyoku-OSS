# =============================================================================
# TIER 3 — PRO (managed, scalable, best answer quality)
# =============================================================================
# Full managed production with autoscaling, dedicated workers, and the strongest
# models. Provision with infra/terraform (see docs/DEVOPS.md) and load these
# values from AWS Secrets Manager rather than a committed file.
#
#   cp .env.pro.example .env   # for reference only; prefer a secret manager
#
# Suggested providers (interchangeable):
#   - Postgres + pgvector : AWS RDS, Crunchy Bridge, Aurora
#   - Redis               : ElastiCache, Redis Cloud
#   - Object storage      : AWS S3 (private, encrypted)
#   - Web + worker        : AWS ECS / Google Cloud Run (run >=1 worker apart)
#   - Model               : Gemini flash for vision, pro/flash for chat
# =============================================================================

NODE_ENV=production
PORT=4173
APP_ORIGIN=https://app.example.com

# Managed Postgres with the `vector` extension enabled
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/hogyoku?sslmode=require

# Managed Redis over TLS
REDIS_URL=rediss://USER:PASSWORD@HOST:6379

# AWS S3 (virtual-hosted style -> FORCE_PATH_STYLE=false)
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=hogyoku-prod-documents
S3_ACCESS_KEY=scoped-bucket-access-key
S3_SECRET_KEY=scoped-bucket-secret-key
S3_FORCE_PATH_STYLE=false

# 64+ random characters, managed and rotated in a secret manager
SESSION_SECRET=replace-with-a-64-character-random-secret

# Higher-quality answers and verification
GEMINI_API_KEY=your-google-ai-studio-key
CHAT_MODEL=gemini-2.5-flash
VISION_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536
# Advanced: a higher-dimension embedding model improves recall but you MUST
# update the vector(1536) column in src/db/migrations/001_initial.sql to match
# this value BEFORE the first migration. Keep 1536 unless you change both.

# Allow larger research PDFs in production
MAX_UPLOAD_MB=75
LOG_LEVEL=info
# Run multiple ingestion workers so OCR never blocks HTTP traffic
WORKER_CONCURRENCY=4
